# Copy this file to .env and fill in your actual values

# Server port and host configuration
PORT=18080
HOST=0.0.0.0

# Frontend origin allowed to call this API with cookies.
# Use a comma-separated list for multiple origins, for example:
# FRONTEND_DOMAIN=http://localhost:5173,https://app.example.com
FRONTEND_DOMAIN=http://localhost:5173

# sqlite, pg, mysql
DATABASE_TYPE=sqlite
DATABASE_URL=./data.db

SESSION_SECRET=your_super_secret_session_key_change_this_in_production
SESSION_MAX_AGE=1209600000  # 14 days
# For true cross-site HTTPS deployments, use:
# SESSION_COOKIE_SAME_SITE=none
# SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false

# Cloud Storage (AWS S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
